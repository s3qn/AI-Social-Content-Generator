# .env.example — copy to .env and fill in real values

# === AI: Embeddings (pick one) ===
VOYAGE_API_KEY=
OPENAI_API_KEY=
APIFY_API_KEY=

# === AI: Media generation ===
RUNWAY_API_KEY=
PIKA_API_KEY=
ELEVENLABS_API_KEY=

# === Instagram Graph API ===
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
# Comma-separated list of chat IDs allowed to use the bot
TELEGRAM_ALLOWED_CHAT_IDS=

# === Pipeline config ===
VAULT_PATH=/home/sean/vault
ENVIRONMENT=development
LOG_LEVEL=INFO
