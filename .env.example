# .env.example — copy to .env and fill in real values

# === AI: Embeddings (pick one) ===
VOYAGE_API_KEY=
OPENAI_API_KEY=
APIFY_API_KEY=

# === AI: Media generation ===
RUNWAY_API_KEY=
PIKA_API_KEY=
ELEVENLABS_API_KEY=

# === Instagram Graph API ===
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Must match the Valid OAuth Redirect URI configured in the Meta app exactly
INSTAGRAM_REDIRECT_URI=https://connect.sean.build/oauth/callback
# Port the in-process aiohttp callback server binds to (Caddy reverse-proxies to it)
OAUTH_CALLBACK_PORT=8081

# === Public image hosting (used to feed JPEGs to the IG publish API) ===
# Where staged JPEGs are written for IG to fetch via curl. Must be writable
# by the bot user and served by a webserver at PUBLIC_IMAGE_BASE_URL.
PUBLIC_IMAGE_DIR=/var/www/img
PUBLIC_IMAGE_BASE_URL=https://img.sean.build

# === Telegram ===
TELEGRAM_BOT_TOKEN=
# Comma-separated list of chat IDs allowed to use the bot
TELEGRAM_ALLOWED_CHAT_IDS=

# === Pipeline config ===
VAULT_PATH=/home/sean/vault
ENVIRONMENT=development
LOG_LEVEL=INFO
